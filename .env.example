# Database
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/elegant_interior_db"

# AI Concierge (Google Gemini)
# Obtain your key at https://aistudio.google.com/
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-api-key"

# Semantic Search (Future Expansion)
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX="elegant-interior-index"

# Contact & Socials
# International format without + (e.g. 15551234567)
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER="15551234567"

# Deployment Metadata
# Your production site URL for SEO and metadata
NEXT_PUBLIC_SITE_URL="https://your-elegant-site.com"
